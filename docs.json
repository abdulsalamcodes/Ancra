{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Ancra",
  "theme": "mint",
  "colors": {
    "primary": "#0a0a0a",
    "light": "#737373",
    "dark": "#0a0a0a"
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "topbar": {
    "style": "default"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/README",
              "docs/getting-started/quickstart",
              "docs/getting-started/authentication",
              "docs/getting-started/errors"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "docs/customers/overview",
              "docs/customers/kyc-tiers"
            ]
          },
          {
            "group": "Virtual Accounts",
            "pages": [
              "docs/virtual-accounts/overview",
              "docs/virtual-accounts/create",
              "docs/virtual-accounts/balance-and-transactions",
              "docs/virtual-accounts/close"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "docs/webhooks/overview",
              "docs/webhooks/events",
              "docs/webhooks/verification"
            ]
          },
          {
            "group": "Transfers",
            "pages": [
              "docs/transfers/overview",
              "docs/transfers/bank-lookup",
              "docs/transfers/initiate"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Configuration",
            "pages": [
              "docs/api-reference/settings",
              "docs/api-reference/auth"
            ]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/abdulsalamcodes/ancra"
  }
}
