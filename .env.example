# =============================================================================
# Ancra — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# HTTP server port
PORT=8080

# PostgreSQL connection string (pgx/v5 DSN format)
DATABASE_URL=postgres://ancra:secret@localhost:5432/ancra?sslmode=disable

# Nomba API credentials
# Obtain from https://dashboard.nomba.com → Settings → API Keys
NOMBA_CLIENT_ID=your_nomba_client_id
NOMBA_CLIENT_SECRET=your_nomba_client_secret

# Your Nomba master account ID (the wallet funds flow through)
NOMBA_ACCOUNT_ID=your_nomba_account_id

# Nomba API base URL (change to sandbox URL during development)
# Sandbox: https://api.nomba.com/v1
# Production: https://api.nomba.com/v1
NOMBA_BASE_URL=https://api.nomba.com/v1

# Secret used to verify HMAC-SHA512 signatures on inbound Nomba webhooks.
# Set this to the value shown in the Nomba dashboard under Webhooks.
NOMBA_WEBHOOK_SECRET=your_nomba_webhook_signing_secret

# Ancra developer API key. Clients must send:
#   Authorization: Bearer <API_KEY>
API_KEY=changeme_use_a_long_random_string

# How often (in seconds) the reconciliation sweep runs.
SWEEP_INTERVAL_SECONDS=60

# (Optional) URL of the developer's endpoint that receives outbound webhooks.
# Leave blank to disable outbound delivery.
WEBHOOK_ENDPOINT=https://yourapp.example.com/hooks/ancra
